deployment:
  enabled: true
  target: eks
  
  # Helm specific settings
  helm:
    chart_path: "charts/demo-maven-app"
    release_name: "demo-maven-app"
  
  # Centralized Genericity Settings
  ingress_domain: "example.com"
  image_pull_secret: "nexus-credentials"

  environments:
    dev:
      enabled: true
      region: ca-central-1
      cluster_name: "devx-reusable-apps-test"
      namespace: "demo-app"
      timeout: "10m"
      atomic: false
      # Additional helm values
      helm:
        set_values: "ingress.enabled=true,ingress.hosts[0].host=demo-maven-app.example.com"
      
      # Health check configuration (used by CD orchestrator)
      health_check:
        enabled: true
        endpoint: "/actuator/health"
        type: "k8s" 
        retries: 10
        retry_interval: 20
      
      auto_rollback: true

    qa:
      enabled: true
      region: ca-central-1
      cluster_name: "demo-maven-app-qa-cluster"
      namespace: "qa-demo-app"
      health_check:
        enabled: true
        endpoint: "/actuator/health"
        type: "k8s"
      auto_rollback: true

    staging:
      enabled: true
      region: ca-central-1
      cluster_name: "demo-maven-app-staging-cluster"
      namespace: "staging-demo-app"
      health_check:
        enabled: true
        endpoint: "/actuator/health"
        type: "k8s"
      auto_rollback: true

    production:
      enabled: true
      region: ca-central-1
      cluster_name: "demo-maven-app-prod-cluster"
      namespace: "prod-demo-app"
      health_check:
        enabled: true
        endpoint: "/actuator/health"
        type: "k8s"
      auto_rollback: true

  notifications:
    enabled: true

# AWS configuration (using OIDC role)
aws:
  default_region: ca-central-1
  role_to_assume: arn:aws:iam::653405621825:role/GitHubActionsRole-test
