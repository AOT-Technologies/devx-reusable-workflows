# DevX CD Configuration for demo-python-app
# This defines the deployment target and health check parameters

deployment:
  enabled: true
  target: eks
  
  # Helm specific settings
  helm:
    chart_path: "charts/demo-python-app"
    release_name: "demo-python-app"
  
  # Centralized Genericity Settings
  image_pull_secret: "nexus-credentials"

  environments:
    dev:
      enabled: true
      region: ca-central-1
      cluster_name: "devx-reusable-apps-test"
      namespace: "demo-app"
      timeout: "10m"
      atomic: false
      # Additional helm values
      helm:
        set_values: "ingress.enabled=false"
      
      # Health check configuration (used by CD orchestrator)
      health_check:
        enabled: true
        endpoint: "/health"
        port: 5000
        type: "k8s" 
      
      # Additional helm values
      values:
        image:
          repository: array-beauty-beyond-previously.trycloudflare.com/docker-hosted/demo-python-app
          pullPolicy: Always
        imagePullSecrets:
          - name: nexus-credentials
        ingress:
          enabled: true
          host: "demo-python.dev.quipohealth.com"
        resources:
          limits:
            cpu: 100m
            memory: 128Mi
          requests:
            cpu: 100m
            memory: 128Mi

# AWS configuration (using OIDC role)
aws:
  default_region: ca-central-1
  role_to_assume: arn:aws:iam::653405621825:role/GitHubActionsRole-test
