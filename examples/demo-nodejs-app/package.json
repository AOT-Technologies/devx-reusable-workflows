{
  "name": "demo-nodejs-app",
  "version": "1.0.0",
  "description": "Demo Node.js app showcasing DevX reusable workflows",
  "main": "dist/index.js",
  "files": [
    "dist",
    "package-lock.json"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --coverage --verbose",
    "test:watch": "jest --watch",
    "build": "esbuild src/index.js --bundle --platform=node --target=node20 --outfile=dist/index.js",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix"
  },
  "keywords": [
    "demo",
    "express",
    "api",
    "devx"
  ],
  "author": "AOT Technologies",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "morgan": "^1.10.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "nodemon": "^3.0.2",
    "eslint": "^8.56.0",
    "esbuild": "^0.19.11"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}